{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "ListRawPrefix",
            "Effect": "Allow",
            "Action": [
                "s3:ListBucket"
            ],
            "Resource": [
                "arn:aws:s3:::oklahoma-gl-test"
            ],
            "Condition": {
                "StringLike": {
                    "s3:prefix": [
                        "raw/*",
                        "raw"
                    ]
                }
            }
        },
        {
            "Sid": "ReadRawObjects",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject",
                "s3:GetObjectVersion"
            ],
            "Resource": [
                "arn:aws:s3:::oklahoma-gl-test/raw/*"
            ]
        }
    ]
}
