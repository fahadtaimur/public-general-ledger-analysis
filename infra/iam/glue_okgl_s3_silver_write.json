{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "ListSilverPrefix",
            "Effect": "Allow",
            "Action": [
                "s3:ListBucket"
            ],
            "Resource": [
                "arn:aws:s3:::oklahoma-gl-test"
            ],
            "Condition": {
                "StringLike": {
                    "s3:prefix": [
                        "silver/*",
                        "silver"
                    ]
                }
            }
        },
        {
            "Sid": "WriteSilverObjects",
            "Effect": "Allow",
            "Action": [
                "s3:PutObject",
                "s3:AbortMultipartUpload",
                "s3:ListMultipartUploadParts"
            ],
            "Resource": [
                "arn:aws:s3:::oklahoma-gl-test/silver/*",
                "arn:aws:s3:::oklahoma-gl-test/silver_$folder$"
            ]
        },
        {
            "Sid": "ListBucketMultipartUploads",
            "Effect": "Allow",
            "Action": [
                "s3:ListBucketMultipartUploads"
            ],
            "Resource": [
                "arn:aws:s3:::oklahoma-gl-test"
            ]
        },
        {
            "Sid": "AllowDeleteForOverwrite",
            "Effect": "Allow",
            "Action": [
                "s3:DeleteObject"
            ],
            "Resource": [
                "arn:aws:s3:::oklahoma-gl-test/silver/*",
                "arn:aws:s3:::oklahoma-gl-test/silver_$folder$"
            ]
        }
    ]
}
